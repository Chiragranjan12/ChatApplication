# =============================================================================
# NEXUS CHAT APPLICATION - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env.local (for development) or .env.production (for prod)
# Replace all placeholder values with your actual configuration
# DO NOT commit .env.local or .env.production to version control
# =============================================================================

# =============================================================================
# SECTION 1: DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
# Connection URL for PostgreSQL database
# Format: jdbc:postgresql://HOST:PORT/DATABASE_NAME
# Example: jdbc:postgresql://localhost:5432/chatdb
DATABASE_URL=jdbc:postgresql://localhost:5432/chatdb

# Database credentials
DB_USERNAME=postgres
DB_PASSWORD=your_database_password_here

# HikariCP Connection Pool Settings
# Maximum number of connections in the pool
DB_POOL_MAX_SIZE=10
# Minimum number of idle connections
DB_POOL_MIN_IDLE=5
# Connection timeout in milliseconds (30 seconds)
DB_POOL_CONNECTION_TIMEOUT=30000
# Idle timeout in milliseconds (10 minutes)
DB_POOL_IDLE_TIMEOUT=600000
# Maximum lifetime of a connection in milliseconds (30 minutes)
DB_POOL_MAX_LIFETIME=1800000

# =============================================================================
# SECTION 2: JWT AUTHENTICATION CONFIGURATION
# =============================================================================
# Secret key for JWT token signing (REQUIRED: minimum 32 characters)
# Generate using: openssl rand -base64 32
# WARNING: Never use this default value in production!
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-minimum-32-characters

# JWT token expiration time in milliseconds
# Default: 86400000 (24 hours)
# Examples:
#   3600000 = 1 hour
#   86400000 = 24 hours
#   604800000 = 7 days
JWT_EXPIRATION=86400000

# Refresh token expiration time in milliseconds (optional, for token refresh)
# Default: 604800000 (7 days)
JWT_REFRESH_EXPIRATION=604800000

# =============================================================================
# SECTION 3: GOOGLE OAUTH2 CONFIGURATION
# =============================================================================
# OAuth2 Client ID from Google Cloud Console
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# OAuth2 Client Secret from Google Cloud Console
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth2 Redirect URI (must match Google Cloud Console configuration)
# Development: http://localhost:8080/api/auth/oauth2/callback/google
# Production: https://your-domain.com/api/auth/oauth2/callback/google
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/oauth2/callback/google

# =============================================================================
# SECTION 4: EMAIL/SMTP CONFIGURATION (Gmail)
# =============================================================================
# SMTP Host (Gmail: smtp.gmail.com)
MAIL_HOST=smtp.gmail.com

# SMTP Port (587 for TLS, 465 for SSL)
MAIL_PORT=587

# Gmail address (your full email address)
MAIL_USERNAME=your-email@gmail.com

# Gmail App Password (NOT your regular password!)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Factor Authentication to be enabled
MAIL_PASSWORD=your-16-character-app-password

# =============================================================================
# SECTION 5: SERVER CONFIGURATION
# =============================================================================
# Server port
PORT=8080

# Active Spring profile (dev, prod, test)
SPRING_PROFILES_ACTIVE=dev

# JPA/Hibernate DDL auto mode (validate, update, create, create-drop)
# WARNING: Use 'validate' in production!
JPA_DDL_AUTO=update

# =============================================================================
# SECTION 6: FRONTEND API & WEBSOCKET URLs
# =============================================================================
# Backend API Base URL (used by frontend)
# Development: http://localhost:8080
# Production: https://your-backend-domain.com
VITE_API_URL=http://localhost:8080

# WebSocket endpoint URL (STOMP over WebSocket)
# Development: ws://localhost:8080/ws
# Production: wss://your-backend-domain.com/ws
VITE_WEBSOCKET_URL=ws://localhost:8080/ws

# =============================================================================
# SECTION 7: LOGGING CONFIGURATION
# =============================================================================
# Log level (TRACE, DEBUG, INFO, WARN, ERROR, OFF)
LOG_LEVEL=INFO
# Application-specific log level
LOG_LEVEL_APP=DEBUG

# Log file path (optional)
# LOG_FILE_PATH=logs/nexus-chat.log

# =============================================================================
# SECTION 8: CORS CONFIGURATION
# =============================================================================
# Allowed origins for CORS (comma-separated)
# Development: http://localhost:3000,http://localhost:5173
# Production: https://your-frontend-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# SECTION 9: RATE LIMITING CONFIGURATION
# =============================================================================
# Maximum requests per minute per IP
RATE_LIMIT_MAX_REQUESTS=60

# Rate limit window in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# =============================================================================
# SECTION 10: CACHE CONFIGURATION
# =============================================================================
# Cache type (simple, caffeine, redis)
CACHE_TYPE=simple

# Caffeine cache spec (maximumSize,expireAfterWrite)
# Example: maximumSize=500,expireAfterWrite=5m
CACHE_CAFFEINE_SPEC=maximumSize=500,expireAfterWrite=5m

# =============================================================================
# SECTION 11: FILE UPLOAD CONFIGURATION
# =============================================================================
# Maximum file size for uploads (in MB)
FILE_UPLOAD_MAX_SIZE=10

# =============================================================================
# SECTION 12: ACTUATOR/MONITORING CONFIGURATION
# =============================================================================
# Enable Prometheus metrics export
METRICS_PROMETHEUS_ENABLED=false

# =============================================================================
# SECTION 13: APPLICATION-SPECIFIC SETTINGS
# =============================================================================
# Random matching queue timeout in seconds
RANDOM_MATCH_TIMEOUT=300

# Maximum message length
MAX_MESSAGE_LENGTH=1000

# Session timeout in milliseconds (30 minutes)
SESSION_TIMEOUT=1800000