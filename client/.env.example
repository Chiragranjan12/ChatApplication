# =============================================================================
# NEXUS CHAT - Frontend Environment Variables Template
# =============================================================================
# Copy this file to .env.local for development
# DO NOT commit actual credentials to version control
# =============================================================================

# =============================================================================
# API & WEBSOCKET CONFIGURATION
# =============================================================================
# Backend API Base URL
# Development: http://localhost:8080
# Production: https://your-backend-production-domain.com
VITE_API_URL=http://localhost:8080

# WebSocket endpoint (use ws:// for HTTP, wss:// for HTTPS)
# Development: ws://localhost:8080/ws
# Production: wss://your-backend-production-domain.com/ws
VITE_WEBSOCKET_URL=ws://localhost:8080/ws

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Application title
VITE_APP_TITLE=Nexus Chat

# Version (auto-populated by Vite)
# VITE_APP_VERSION=1.0.0

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable debug features (disable in production)
# VITE_DEBUG_MODE=true

# Enable analytics (set to false for privacy)
# VITE_ANALYTICS_ENABLED=false

# =============================================================================
# EXTERNAL SERVICES (optional)
# =============================================================================
# Sentry DSN for error tracking (optional)
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Google Analytics ID (optional)
# VITE_GA_ID=G-XXXXXXXXXX